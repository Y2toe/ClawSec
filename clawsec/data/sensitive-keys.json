{
  "_meta": {
    "description": "Patterns for identifying sensitive keys in config files",
    "lastUpdated": "2026-03-10"
  },
  "keyPatterns": [
    "password",
    "passwd",
    "secret",
    "token",
    "api_key",
    "apikey",
    "private_key",
    "access_key",
    "client_secret"
  ],
  "configCredentialRegex": "(?:password|passwd|secret|token|api_key|apikey|private_key|access_key|client_secret)\\s*[:=]\\s*['\"]?[\\w\\-\\.]{1,}['\"]?"
}
